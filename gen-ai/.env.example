GENAI_DATABASE_BACKEND=postgres
GENAI_POSTGRES_DSN=postgresql://db_user:db_password_placeholder@localhost:5432/genai_service

POSTGRES_DB=genai_service
POSTGRES_USER=example_user
POSTGRES_PASSWORD=db_password_placeholder
POSTGRES_PORT=5432

GENAI_APP_HOST=127.0.0.1
GENAI_APP_PORT=8000
GENAI_WORKER_POLL_INTERVAL=5

# Optional runtime controls
GENAI_ENABLE_JOB_PROCESS_API=true
GENAI_USE_WORKER_FOR_DIRECT_ENRICHMENT=false
GENAI_DIRECT_ENRICHMENT_WAIT_TIMEOUT=30
GENAI_DIRECT_ENRICHMENT_POLL_INTERVAL=0.5
GENAI_XAI_BACKEND=attention
GENAI_ENABLE_INLINE_XAI=true

# Optional Groq generation for summaries and localized UI-facing fields.
GROQ_API_KEY=
GROQ_API_BASE_URL=https://api.groq.com/openai/v1
GROQ_SUMMARY_MODEL=llama-3.1-8b-instant
GROQ_TRANSLATION_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_SECONDS=20
GROQ_SUMMARY_SOFT_CHAR_LIMIT=3500
GROQ_SUMMARY_HARD_CHAR_LIMIT=6500
GROQ_TRANSLATION_CHAR_LIMIT=1200

# Optional: enable browser/API Basic Auth when both values are set.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
